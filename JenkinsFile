pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/vs-vanshika/MyMavenSeleniumApp02.git',
                    credentialsId: 'GitHubCredential'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Run') {
            steps {
                sh 'mvn exec:java -Dexec.mainClass="com.example.App"'
            }
        }
    }

    post {
        success {
            echo ' Build and Run successful!'
        }
        failure {
            echo ' Build failed!'
        }
    }
}
